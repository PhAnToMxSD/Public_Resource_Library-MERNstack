  "name": "public_resource_library-mernstack",
  "version": "1.0.0",
  "description": "This is a public resource library where people can upload links/documents as resources, to help the community grow and learn from each other.",
  "main": "App.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "start:client": "concurrently \"npx @tailwindcss/cli -i ./src/input.css -o ./src/output.css --watch\" \"react-scripts start\"",
    "build:css": "npx @tailwindcss/cli -i ./src/input.css -o ./src/output.css --minify",
    "build": "npm run build:css && react-scripts build"
  },
